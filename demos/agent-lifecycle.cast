{"version":3,"term":{"cols":80,"rows":24},"timestamp":1777612587,"command":"/tmp/demo-script.sh","env":{"SHELL":"/bin/bash"}}
[0.001, "o", "=== Nous Agent Lifecycle Demo ===\r\n\r\n"]
[1.000, "o", "# 1. Register a new agent\r\n"]
[0.010, "o", "   Agent ID: 019de1f7-85f7-72e1-8e92-81d420516d81\r\n"]
[1.003, "o", "\r\n# 2. Spawn agent process with shell command\r\n"]
[0.018, "o", "\u001b[1;39m{\u001b[0m\u001b[1;34m\"agent_id\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"019de1f7-85f7-72e1-8e92-81d420516d81\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"pending\"\u001b[0m\u001b[1;39m}\u001b[0m\r\n"]
[2.008, "o", "\r\n# 3. List all running agent processes\r\n"]
[0.016, "o", "\u001b[1;39m[\u001b[0m\u001b[1;39m{\u001b[0m\u001b[1;34m\"agent_id\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"019de1f7\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"pending\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"pid\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;90mnull\u001b[0m\u001b[1;39m}\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;39m{\u001b[0m\u001b[1;34m\"agent_id\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"019de1a8\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"running\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"pid\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;39m2067187\u001b[0m\u001b[1;39m}\u001b[0m\u001b[1;39m]\u001b[0m\r\n"]
[1.009, "o", "\r\n# 4. Invoke agent synchronously\r\n"]
[0.030, "o", "\u001b[1;39m{\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"completed\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"result\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"Hello from agent\\n\"\u001b[0m\u001b[1;39m}\u001b[0m\r\n"]
[1.015, "o", "\r\n# 5. Invoke agent asynchronously\r\n"]
[0.026, "o", "   (async invocations pending implementation)\r\n"]
[1.005, "o", "\r\n# 7. List all invocations for agent\r\n"]
[0.014, "o", "\u001b[1;39m[\u001b[0m\u001b[1;39m{\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"completed\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"started_at\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"2026-05-01T05:16:33.655Z\"\u001b[0m\u001b[1;39m}\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;39m{\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"completed\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"started_at\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"2026-05-01T05:16:32.618Z\"\u001b[0m\u001b[1;39m}\u001b[0m\u001b[1;39m]\u001b[0m\r\n"]
[1.007, "o", "\r\n# 8. View agent process logs\r\n"]
[0.015, "o", "\u001b[1;39m[\u001b[0m\u001b[1;39m{\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"pending\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"started_at\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;90mnull\u001b[0m\u001b[1;39m}\u001b[0m\u001b[1;39m]\u001b[0m\r\n"]
[1.014, "o", "\r\n# 9. Stop agent process\r\n"]
[0.021, "o", "\u001b[1;39m{\u001b[0m\u001b[1;34m\"agent_id\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"019de1f7-85f7-72e1-8e92-81d420516d81\"\u001b[0m\u001b[1;39m,\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"stopped\"\u001b[0m\u001b[1;39m}\u001b[0m\r\n"]
[1.006, "o", "\r\n# 10. Restart agent process\r\n"]
[2.018, "o", "\r\n# 11. Stop agent before deregister\r\n"]
[1.022, "o", "\r\n# 12. Deregister agent\r\n"]
[0.031, "o", "\u001b[1;39m{\u001b[0m\u001b[1;34m\"status\"\u001b[0m\u001b[1;39m:\u001b[0m\u001b[0;32m\"deregistered\"\u001b[0m\u001b[1;39m}\u001b[0m\r\n"]
[1.014, "o", "\r\n=== Demo complete ===\r\n"]
[0.001, "x", "0"]
